APP_NAME=Отукен
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
# Для Docker с портом 8081 задайте тот же хост, что в браузере — иначе ссылки на /storage и превью в Filament ломаются.
APP_URL=http://localhost:8081
# Опционально: для artisan (export PHP_MEMORY_LIMIT=1G) или php-fpm pool env. В public/index.php при пустом getenv используется 512M.
# PHP_MEMORY_LIMIT=512M

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Обложки новостей (Spatie Media Library) хранятся на диске public → storage/app/public и отдаются через public/storage (php artisan storage:link). В Docker уже вызывается storage:link при старте app.
# MEDIA_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
# Reg.ru: smtps + порт 465 (SSL) или smtp + 587 (STARTTLS)
MAIL_SCHEME=smtps
MAIL_HOST=mail.hosting.reg.ru
MAIL_PORT=465
MAIL_USERNAME=support@отукен.рф
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="support@отукен.рф"
MAIL_FROM_NAME="${APP_NAME}"

# Куда приходят заявки с формы «Интерес к району» (Gmail, Яндекс и т.д.)
LEADS_MANAGER_EMAIL=

# URL лендинга для CORS (если фронт на другом домене, чем API)
LANDING_SITE_URL=https://отукен.рф

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-20b:free
OPENROUTER_MODELS=openai/gpt-oss-20b:free,openai/gpt-oss-120b:free,google/gemma-4-31b-it:free,meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

OPENROUTER_ENABLE_TUV_STUDIO_TRANSLATION=false

ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password
